// ═══ UNITS ═══
let uid=0;
const mk=(name,team,x,y,stats,techNames=[],behavior="aggressive",charge=null)=>{
  const techs=techNames.map(n=>{const t=TECHS[n];return t?{...t,uses:t.maxUses}:null;}).filter(Boolean);
  return{id:`u${uid++}`,name,team,x,y,...stats,techs,skills:[],items:[],acted:false,exp:0,level:stats.level||1,
    cls:"enemy",tags:[],behavior,debuffs:[],
    ...(team==="enemy"?{expPool:EXP_POOL}:{}),
    chargeTech:charge?TECHS[charge.tech]||null:null,
    chargeTurns:charge?.turns||0,chargeCounter:0,chargeRepeat:charge?.repeat||false};
};
const mkP=(name,stats,tags,initTechs)=>{
  const techs=initTechs.map(n=>{const t=TECHS[n];return t?{...t,uses:t.maxUses}:null;}).filter(Boolean);
  return{id:`u${uid++}`,name,team:"player",x:-1,y:-1,...stats,techs,skills:[],
    items:[{name:"傷薬",heal:15,uses:1,maxUses:1,desc:"HP15回復 消耗品"}],
    acted:false,exp:0,level:1,cls:"冒険者",tags,initTechs,
    behavior:"player",debuffs:[],deployed:false};
};

