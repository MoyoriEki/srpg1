// ═══ CLASS SYSTEM ═══
const CLASS_DATA={
  "冒険者":{tier:"初級",growth:{hp:2.5,str:0.8,def:0.8,int:0.8},ts:2,ss:1,is:1},
  "炎闘士":{tier:"中級",growth:{hp:2.5,str:1.3,def:0.8,int:0.5},ts:3,ss:2,is:1,tag:"fire"},
  "水盾士":{tier:"中級",growth:{hp:3.0,str:0.5,def:1.3,int:0.8},ts:3,ss:2,is:1,tag:"water"},
  "風術師":{tier:"中級",growth:{hp:2.0,str:0.8,def:0.5,int:1.3},ts:3,ss:2,is:1,tag:"wind"},
  "スレイヤー":{tier:"上級",trait:"canto",growth:{hp:3.0,str:1.5,def:0.8,int:0.5},ts:6,ss:4,is:3,rMin:1,rMax:1},
  "ヴァンガード":{tier:"上級",trait:"revenge",growth:{hp:3.5,str:1.0,def:1.3,int:0.6},ts:5,ss:4,is:4,rMin:1,rMax:1},
  "フォートレス":{tier:"上級",trait:"miracle",growth:{hp:4.0,str:0.5,def:1.6,int:0.8},ts:5,ss:4,is:4,rMin:1,rMax:1},
  "プロテクター":{tier:"上級",trait:"shieldAura",growth:{hp:3.0,str:0.5,def:1.3,int:1.0},ts:6,ss:4,is:3,rMin:1,rMax:2},
  "ソーサラー":{tier:"上級",trait:"rangeBoost",growth:{hp:2.0,str:1.3,def:0.5,int:1.2},ts:6,ss:4,is:3,rMin:2,rMax:2},
  "オラクル":{tier:"上級",trait:"healBoost",growth:{hp:2.0,str:0.8,def:0.5,int:1.3},ts:7,ss:4,is:2,rMin:1,rMax:1},
};
const MID_CC={"fire":"炎闘士","water":"水盾士","wind":"風術師"};
const ADV_CC={"炎闘士_water":["スレイヤー","ヴァンガード"],"炎闘士_wind":["スレイヤー","ソーサラー"],
  "水盾士_fire":["フォートレス","ヴァンガード"],"水盾士_wind":["フォートレス","プロテクター"],
  "風術師_fire":["オラクル","ソーサラー"],"風術師_water":["オラクル","プロテクター"]};
function getSlots(unit){const c=CLASS_DATA[unit.cls];const b=unit._bonusSlots||{t:0,s:0,i:0};return c?{t:c.ts+b.t,s:999,i:c.is+b.i}:{t:2+b.t,s:999,i:1+b.i};}
function getCCOptions(unit){
  if(unit.level===5&&unit.cls==="冒険者")return{type:"mid",opts:unit.tags.map(t=>MID_CC[t])};
  if(unit.level===10&&CLASS_DATA[unit.cls]?.tier==="中級"){
    const midTag=CLASS_DATA[unit.cls].tag;const other=unit.tags.find(t=>t!==midTag);
    return{type:"adv",opts:ADV_CC[`${unit.cls}_${other}`]||[]};}
  return null;
}
function applyCC(unit,newCls){const u={...unit};u.cls=newCls;
  const cd=CLASS_DATA[newCls];if(cd?.rMin!==undefined){u.rangeMin=cd.rMin;u.rangeMax=cd.rMax;}
  if(cd?.mov)u.mov=cd.mov;
  if(cd?.pp!==undefined)u.pp=(u.pp||0)+cd.pp;
  const ccBonus={
    "炎闘士":{hp:2,str:2,def:1,int:0},"水盾士":{hp:4,str:0,def:2,int:0},"風術師":{hp:2,str:1,def:0,int:2},
    "スレイヤー":{hp:4,str:4,def:1,int:-1},"ヴァンガード":{hp:5,str:2,def:2,int:0},
    "フォートレス":{hp:8,str:-1,def:4,int:1},"プロテクター":{hp:5,str:-1,def:2,int:2},
    "オラクル":{hp:3,str:0,def:-1,int:4},"ソーサラー":{hp:0,str:2,def:-1,int:2}};
  const b=ccBonus[newCls];if(b){u.maxHp+=b.hp;u.hp+=b.hp;u.str+=b.str;u.def+=b.def;u.int+=b.int;}return u;}

