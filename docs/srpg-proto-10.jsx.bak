    mkP("ベルグ",{hp:50,maxHp:50,str:11,def:15,int:5,mov:3,rangeMin:1,rangeMax:1},["water","fire"],["鉄壁の構え","猛撃"]),
    mkP("ドーラ",{hp:38,maxHp:38,str:16,def:8,int:9,mov:4,rangeMin:1,rangeMax:1},["fire","water"],["猛撃","シールドバッシュ"]),
    mkP("ジンク",{hp:45,maxHp:45,str:8,def:13,int:11,mov:4,rangeMin:1,rangeMax:1},["water","wind"],["シールドバッシュ","ヒール"]),
    mkP("ヘイゼル",{hp:35,maxHp:35,str:7,def:9,int:15,mov:4,rangeMin:1,rangeMax:1},["wind","water"],["ヒール","鉄壁の構え"]),
    mkP("ヤシュカ",{hp:42,maxHp:42,str:9,def:12,int:13,mov:3,rangeMin:1,rangeMax:1},["water","wind"],["鉄壁の構え","ブレイク"]),
    mkP("トーヴァ",{hp:30,maxHp:30,str:13,def:5,int:14,mov:4,rangeMin:2,rangeMax:2},["wind","fire"],["ブレイク","狙い撃ち"]),
    mkP("ニカ",{hp:28,maxHp:28,str:10,def:6,int:17,mov:4,rangeMin:1,rangeMax:1},["wind","fire"],["ヒール","猛撃"]),
